{
  "name": "enmax-spark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch server/index.ts\" \"vite --port=3000\"",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "db:reset": "rm -f data/spark.db && echo 'Database reset'",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "docker:build": "docker build -t enmax-spark .",
    "docker:run": "docker run -p 3001:3001 -v spark-data:/app/data -e OPENROUTER_API_KEY=$OPENROUTER_API_KEY enmax-spark"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^5.1.0",
    "framer-motion": "^12.6.3",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
